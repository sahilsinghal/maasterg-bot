# MAAsterG Bot Configuration
# Copy this file to .env and fill in your values

# Node Environment
PORT=3000
NODE_ENV=production

# Google Sheet lead sync (optional)
# Paste the Google Apps Script Web App URL here (see DATA_CAPTURE.md).
# Kept in .env so it stays OUT of git. Falls back to
# settings.googleSheetWebhookUrl in config/menu.json if unset.
GOOGLE_SHEET_WEBHOOK_URL=

# Optional: For future enhancements
# DATABASE_URL=
# ADMIN_PHONE=
# LOG_LEVEL=debug
